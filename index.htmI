<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Ali Hussam • Legend</title>

<style>
body{
  margin:0;
  font-family:Arial;
  color:white;
  background: radial-gradient(circle at top, #2b0000, #000);
  overflow:hidden;
}

/* HERO */
.hero{
  text-align:center;
  padding:50px 20px;
}

.avatar{
  width:130px;
  height:130px;
  margin:auto;
  border-radius:50%;
  overflow:hidden;
  border:2px solid red;
  box-shadow:0 0 25px red;
}

.avatar img{
  width:100%;
  height:100%;
  object-fit:cover;
}

h1{
  margin-top:15px;
  text-shadow:0 0 15px red;
  font-size:28px;
}

.subtitle{
  color:rgba(255,255,255,0.7);
  margin-top:5px;
  font-size:14px;
  letter-spacing:1px;
}

/* CARDS */
.container{
  max-width:800px;
  margin:auto;
  padding:20px;
}

.card{
  background:rgba(255,255,255,0.05);
  margin:10px auto;
  padding:15px;
  border-radius:12px;
  border:1px solid rgba(255,0,0,0.3);
  transition:0.3s;
}

.card:hover{
  transform:scale(1.05);
  box-shadow:0 0 20px red;
}

a{
  color:red;
  font-weight:bold;
  text-decoration:none;
}

/* floating light */
.glow{
  position:absolute;
  width:200px;
  height:200px;
  background:red;
  filter:blur(120px);
  opacity:0.2;
  animation:move 6s infinite alternate;
}

@keyframes move{
  from{transform:translate(0,0)}
  to{transform:translate(200px,200px)}
}
</style>
</head>

<body>

<div class="glow"></div>

<div class="hero">

  <div class="avatar">
    <img src="ttt.jpg">
  </div>

  <h1>Ali Hussam</h1>

  <div class="subtitle">
    Football Player • Passionate Folk Poet • Ambitious & Driven
  </div>

</div>

<div class="container">

  <div class="card">
    <h3>Instagram</h3>
    <a href="https://instagram.com/lr2_f">Follow</a>
  </div>

  <div class="card">
    <h3>TikTok</h3>
    <a href="https://tiktok.com/@lr2_f">Watch</a>
  </div>

  <div class="card">
    <h3>Telegram</h3>
    <a href="https://t.me/lr2_f">Contact</a>
  </div>

  <div class="card">
    <h3>Email</h3>
    <a href="mailto:ddss10218@gmail.com">Send Message</a>
  </div>

</div>

</body>
</html>
